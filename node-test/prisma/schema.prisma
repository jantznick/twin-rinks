generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Twin Rinks app user preferences keyed by login email (legacy subs login).
model User {
  id                       String   @id @default(cuid())
  email                    String   @unique
  sportsengineCalendarUrls String[] @default([])
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}
