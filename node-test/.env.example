# Copy to `.env` in this directory before `docker compose up`.
# Prisma and PostgreSQL are intended to run only via Docker (see docker-compose.yml).

PORT=3001
LEGACY_BASE_URL=https://hockeydomain.com/adulthockey/subs
LEGACY_LOGIN_PATH=/subs_entry.php
LEGACY_GAMES_PATH=/all_player_login.php
LEGACY_SUBMIT_PATH=/cgi-bin/bnbform.cgi
BODY_PREVIEW_LIMIT=4000
LOG_SENSITIVE=0
SITE_ACCESS_PASSWORD=your_secret_password_here
FRONTEND_URL=http://localhost:5173

# Used when the API runs in Docker Compose; compose also sets DATABASE_URL explicitly to the `db` service.
# DATABASE_URL=postgresql://twinrinks:twinrinks@db:5432/twin_rinks?schema=public

# Optional: only if something calls GET /sportsengine/team-schedule without a `url` parameter.
# DEFAULT_SPORTSENGINE_TEAM_SCHEDULE_URL=https://www.example.com/schedule/team_instance/1?subseason=1

# --- Docker (from this `node-test` directory) ---
#   cp .env.example .env
#   docker compose up --build
#   # or: npm run docker:up
#
# Prisma (must run inside the api container — npm scripts wrap docker compose):
#   npm run db:generate
#   npm run db:migrate
#   npm run db:migrate:dev
